# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (optional — billing disabled if not set)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_DAILY_ID=price_...
STRIPE_PRICE_PREMIUM_WEEKLY_ID=price_...
STRIPE_PRICE_PREMIUM_MONTHLY_ID=price_...

# Quotas (optional — defaults: 30 questions/day, 5 fiches/day)
FREE_DAILY_QUESTION_LIMIT=30
FREE_DAILY_FICHE_LIMIT=5

# Web Push Notifications (optional — disabled if not set)
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@crpe-francais.fr
